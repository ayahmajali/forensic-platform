# ─────────────────────────────────────────
# Digital Forensics Investigation Platform
# Environment Configuration
#
# IMPORTANT: keep comments on their OWN lines. Some loaders do not strip
# trailing "# ..." comments from value lines.
# ─────────────────────────────────────────

# ── OpenAI (optional) ────────────────────
# Enables AI-powered case summaries. Leave blank to use the local template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Server ───────────────────────────────
HOST=0.0.0.0
PORT=8000
# Upload size limit in MB
MAX_UPLOAD_SIZE=2048

# ── Persistent storage (MongoDB) ─────────
# If MONGODB_URI is blank OR unreachable, the backend transparently falls
# back to an in-memory store so demos never break.
#
# Local MongoDB (Homebrew on macOS or MongoDB Community on Windows):
MONGODB_URI=mongodb://localhost:27017
#
# MongoDB Atlas (cloud, free tier):
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#
MONGODB_DB=forensic_platform
# Connect timeout in milliseconds
MONGODB_TIMEOUT=2000

# ── Agent authentication ─────────────────
# The CLI agent (agent/forensic_agent.py) must send X-API-Key equal to this.
# Generate a random one:   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank to disable /api/agent/upload (fails closed with 503).
AGENT_API_KEY=
