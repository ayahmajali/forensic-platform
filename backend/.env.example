# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Server configuration
HOST=0.0.0.0
PORT=8000

# Upload size limit (in MB)
MAX_UPLOAD_SIZE=2048
